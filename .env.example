# Frontend environment template — copy to `.env.local` and adjust per environment.
#
# Base URL of the EchoVault demo backend (FastAPI app in
# `~/Demo for EchoVaultAI/echovault-backend-demo/`). Read by
# `src/services/api-client.ts` via `import.meta.env.VITE_BACKEND_URL`.
VITE_BACKEND_URL=http://localhost:8000

# Formspree form id used by the waitlist page. Defaults to the project's
# baked-in id at `DEFAULT_FORMSPREE_ID` if unset; override here per
# deployment environment so production points at a different form than
# dev or staging. Read by `src/services/waitlist.ts`.
VITE_FORMSPREE_ID=xaqkaayp
